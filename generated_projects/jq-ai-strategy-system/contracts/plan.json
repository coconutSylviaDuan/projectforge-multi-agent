    "framework": "FastAPI",
    "database": "SQLite",
    "services": [
      "auth_service",
      "strategy_service",
      "backtest_service",
      "chat_service"
    ],
    "models": [
      "User",
      "Strategy",
      "BacktestResult"
    ],
    "api_contract": {
      "base_url": "/api",
      "endpoints": [
        {
          "method": "POST",
          "path": "/api/auth/register",
          "purpose": "Register a new user account",
          "request_schema": {
            "username": "string",
            "password": "string"
          },
          "response_schema": {
            "id": "integer",
            "username": "string"
          }
        },
        {
          "method": "POST",
          "path": "/api/auth/login",
          "purpose": "Login and receive JWT token",
          "request_schema": {
            "username": "string",
            "password": "string"
          },
          "response_schema": {
            "access_token": "string",
            "token_type": "string"
          }
        },
        {
          "method": "POST",
          "path": "/api/chat/generate",
          "purpose": "Generate strategy code from user prompt using AI",
          "request_schema": {
            "prompt": "string",
            "history": "array"
          },
          "response_schema": {
            "code": "string",
            "strategy_id": "integer"
          }
        },
        {
          "method": "POST",
          "path": "/api/strategies",
          "purpose": "Save (create or update) a strategy",
          "request_schema": {
            "id": "integer",
            "name": "string",
            "description": "string",
            "code": "string"
          },
          "response_schema": {
            "id": "integer",
            "created_at": "string"
          }
        },
        {
          "method": "GET",
          "path": "/api/strategies",
          "purpose": "List all strategies for the current user",
          "request_schema": {},
          "response_schema": {
            "strategies": "array"
          }
        },
        {
          "method": "GET",
          "path": "/api/strategies/{id}",
          "purpose": "Get detailed info of a single strategy",
          "request_schema": {},
          "response_schema": {
            "id": "integer",
            "name": "string",
            "description": "string",
            "code": "string",
            "created_at": "string",
            "bound_backtest_id": "integer"
          }
        },
        {
          "method": "DELETE",
          "path": "/api/strategies/{id}",
          "purpose": "Delete a strategy by id",
          "request_schema": {},
          "response_schema": {}
        },
        {
          "method": "POST",
          "path": "/api/backtest/quick",
          "purpose": "Execute quick backtest and return result",
          "request_schema": {
            "code": "string",
            "strategy_id": "integer"
          },
          "response_schema": {
            "backtest_id": "integer",
            "result": "object"
          }
        },
        {
          "method": "POST",
          "path": "/api/backtest/analysis",
          "purpose": "Execute full backtest performance analysis, bind to strategy",
          "request_schema": {
            "strategy_id": "integer",
            "code": "string"
          },
          "response_schema": {
            "backtest_id": "integer",
            "redirect_url": "string"
          }
        },
        {
          "method": "GET",
          "path": "/api/backtest-results",
          "purpose": "List backtest results for current user, optional type filter",
          "request_schema": {
            "type": "string"
          },
          "response_schema": {
            "results": "array"
          }
        },
        {
          "method": "GET",
          "path": "/api/backtest-results/{id}",
          "purpose": "Get detailed backtest result including performance data",
          "request_schema": {},
          "response_schema": {
            "id": "integer",
            "type": "string",
            "result_data": "object",
            "strategy_id": "integer"
          }
        },
        {
          "method": "POST",
          "path": "/api/chat/continue",
          "purpose": "Continue multi-turn AI dialogue to modify strategy code",
          "request_schema": {
            "strategy_id": "integer",
            "message": "string",
            "history": "array"
          },
          "response_schema": {
            "code": "string",
            "reply": "string"
          }
        }
      ],
      "shared_types": [
        {
          "User": "object with fields id, username, password_hash"
        },
        {
          "Strategy": "object with fields id, user_id, name, description, code, created_at, updated_at, bound_backtest_id"
        },
        {
          "BacktestResult": "object with fields id, strategy_id, user_id, type, result_data, created_at"
        }
      ],
      "error_shape": {
        "detail": "string",
        "error_code": "string"
      }
